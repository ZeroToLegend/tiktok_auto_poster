# TikTok Developer Credentials
# Đăng ký tại: https://developers.tiktok.com
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here
TIKTOK_REDIRECT_URI=http://localhost:8000/callback

# Lấy bằng cách chạy: python scripts/oauth_setup.py
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=

# KHÔNG cần ANTHROPIC_API_KEY nữa!
# Hệ thống dùng Claude Code CLI với account Pro/Max của bạn.
# Cài đặt:
#   1. npm install -g @anthropic-ai/claude-code (hoặc theo docs)
#   2. claude login  (login bằng account Claude.ai Pro)
#   3. claude -p "test"  (verify hoạt động)
# Chi tiết: https://docs.claude.com/en/docs/claude-code/setup

# Optional: multiple accounts
# Thêm prefix để dùng agent với nhiều account
# TIKTOK_ACCOUNT2_ACCESS_TOKEN=
# TIKTOK_ACCOUNT2_REFRESH_TOKEN=
